# ============================================================
# LiteFrame VM Cluster - 环境变量模板
# 复制为 .env 后修改实际值，.env 不提交 git
# 参考: docker-compose.yaml, scripts/*.sh
# ============================================================

# --- 宿主机 ---
COMPOSE_PROJECT_NAME=liteframe-metrics

# --- 服务地址（内网）---
# CVM 本地脚本、容器间通信使用
GRAFANA_HOST_NAME_INTERNAL=10.12.28.83
KEYCLOAK_HOST_NAME_INTERNAL=10.12.28.83
VMAUTH_HOST_NAME_INTERNAL=10.12.28.83

# --- 服务地址（外网）---
# 浏览器访问、vmalert 告警链接、外部业务写入
# 升级 HTTPS + 域名时修改对应 _HOST_NAME_EXTERNAL 和 _SCHEME_EXTERNAL
GRAFANA_HOST_NAME_EXTERNAL=10.12.28.83
GRAFANA_SCHEME_EXTERNAL=http
KEYCLOAK_HOST_NAME_EXTERNAL=10.12.28.83
KEYCLOAK_SCHEME_EXTERNAL=http
VMAUTH_HOST_NAME_EXTERNAL=10.12.28.83
VMAUTH_SCHEME_EXTERNAL=http

# --- 时区 ---
TZ=Asia/Shanghai

# --- 端口 ---
GRAFANA_PORT=3000
KC_PORT=3001
VMAUTH_PORT=8427
VMAGENT_PORT=8429
VMALERT_PORT=8880

# --- 镜像版本 ---
GRAFANA_VERSION=12.4.0
KEYCLOAK_VERSION=26.6.1
VICTORIAMETRICS_VERSION=v1.142.0
ALERTMANAGER_VERSION=v0.28.1

# --- Keycloak 独立 Realm（Grafana OIDC 使用）---
KC_REALM=grafana
# Keycloak realm SSL 策略。纯 HTTP 公网部署必须设为 NONE；启用 HTTPS 后建议改为 external 或 all。
KEYCLOAK_SSL_REQUIRED=NONE

# --- Bootstrap 临时管理员（仅初始化使用，完毕后会被 disable）---
KC_BOOTSTRAP_ADMIN_USER=admin-temporay
KC_BOOTSTRAP_ADMIN_PASS=change_me

# --- 永久 Keycloak 管理员 ---
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin_pass
KC_ADMIN_EMAIL=admin@example.com

# --- 容器运行用户 ---
# 写入宿主机 data 目录的容器使用该 UID/GID 运行，默认 1001:1001。
# Keycloak 官方镜像固定使用 UID 1000 写入 keycloak/data；init 会检查该目录权限。
CONTAINER_USER_ID=1001
CONTAINER_GROUP_ID=1001

# --- Grafana ---
# Grafana 内置 admin 用户名/密码（脚本调用 API 使用 Basic Auth，OAuth 生效后不再用于登录）
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Grafana OIDC 管理员用户名/密码（Keycloak 中创建的 OIDC 用户，用于浏览器登录 Grafana）
GF_OIDC_ADMIN_USER=admin
GF_OIDC_ADMIN_PASS=admin

# --- Grafana OIDC Client Secret（Keycloak 中 grafana client 使用）---
GRAFANA_CLIENT_SECRET=NNDNCAXndSnQa6tLVbIUGtFanPLGpqo5

# --- vmauth 内部写入账号（vmagent/vmalert 使用）---
VMADMIN_PASS=vmadmin_pass

# --- VictoriaMetrics ---
# 指标保留周期。示例：30d、90d、180d。缩短该值会让更早的数据进入可清理范围。
VM_RETENTION_PERIOD=90d

# --- Docker resource limits ---
# 默认面向 4C/8G staging 单机部署，可按机器规格在 .env 中调大。
GRAFANA_CPUS=0.50
GRAFANA_MEM_LIMIT=512m
GRAFANA_MEM_RESERVATION=192m

KEYCLOAK_CPUS=0.75
KEYCLOAK_MEM_LIMIT=1g
KEYCLOAK_MEM_RESERVATION=384m

VMSTORAGE_CPUS=0.90
VMSTORAGE_MEM_LIMIT=1536m
VMSTORAGE_MEM_RESERVATION=768m

VMSELECT_CPUS=0.60
VMSELECT_MEM_LIMIT=768m
VMSELECT_MEM_RESERVATION=256m

VMINSERT_CPUS=0.35
VMINSERT_MEM_LIMIT=256m
VMINSERT_MEM_RESERVATION=64m

VMAUTH_CPUS=0.30
VMAUTH_MEM_LIMIT=256m
VMAUTH_MEM_RESERVATION=64m

VMAGENT_CPUS=0.40
VMAGENT_MEM_LIMIT=384m
VMAGENT_MEM_RESERVATION=128m

VMALERT_CPUS=0.40
VMALERT_MEM_LIMIT=384m
VMALERT_MEM_RESERVATION=128m

ALERTMANAGER_CPUS=0.20
ALERTMANAGER_MEM_LIMIT=128m
ALERTMANAGER_MEM_RESERVATION=64m
